#### 2.3 Smart Routing (AODV-Lite)

```kotlin
// Ganti pure flooding dengan AODV-lite
class MeshRouterAodv {
    private val routeTable = ConcurrentHashMap<String, RouteEntry>()
    private val helloInterval = 5_000L // ms

    data class RouteEntry(
        val destination: String,
        val nextHop: String,
        val hopCount: Int,
        val nodeScore: Float,  // battery+signal+load composite
        val sequenceNumber: Int,
        val expiryTime: Long
    )

    fun selectRoute(destinationId: String): RouteEntry? {
        return routeTable[destinationId]
            ?.takeIf { it.expiryTime > System.currentTimeMillis() }
    }

    fun updateNodeScore(peerId: String, battery: Int, rssi: Int, relayLoad: Int) {
        val score = (battery * 0.35f) + 
                    (normalizeRSSI(rssi) * 0.35f) + 
                    ((1f / maxOf(relayLoad, 1)) * 0.30f)
        // Update routing table weight
    }
}
```

