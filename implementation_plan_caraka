## `CourierCryptoHelper` — Implementasi Kritis

```kotlin
object CourierCryptoHelper {

    /**
     * Derive claim token dari EPK_pub + nonce rahasia.
     * Hasilnya adalah string 32-char hex — tidak mengungkap isi apapun.
     */
    fun deriveClaimToken(epkPub: ByteArray, nonce: ByteArray): String {
        val input = epkPub + nonce
        val hash = lazySodium.cryptoGenericHash(input, 16) // BLAKE2b 16 bytes
        return hash.toHexString()
    }

    /**
     * Derive symmetric key dari EPK_priv untuk secretbox (Mode Stealth).
     * Menggunakan BLAKE2b-256 sebagai KDF — deterministic, tidak reversible.
     */
    fun deriveSymKey(epkPriv: ByteArray): ByteArray {
        return lazySodium.cryptoGenericHash(epkPriv, 32) // 256-bit key
    }

    /**
     * Enkripsi payload untuk Stealth Mode.
     * Tidak ada identitas pengirim dalam output.
     */
    fun stealthEncrypt(plaintext: String, epkPriv: ByteArray): Pair<String, String> {
        val symKey = deriveSymKey(epkPriv)
        val nonce = lazySodium.nonce(SecretBox.NONCEBYTES)
        val ciphertext = lazySodium.cryptoSecretBoxEasy(plaintext, nonce, Key.fromBytes(symKey))
        return Pair(
            Base64.encodeToString(ciphertext, Base64.NO_WRAP),
            Base64.encodeToString(nonce, Base64.NO_WRAP)
        )
    }

    /**
     * Dekripsi Stealth payload — Z menggunakan EPK_priv yang diterima dari A.
     */
    fun stealthDecrypt(encPayloadB64: String, encNonceB64: String, epkPriv: ByteArray): String? {
        val symKey = deriveSymKey(epkPriv)
        val nonce = Base64.decode(encNonceB64, Base64.NO_WRAP)
        val ciphertext = Base64.decode(encPayloadB64, Base64.NO_WRAP)
        return lazySodium.cryptoSecretBoxOpenEasy(
            Base64.encodeToString(ciphertext, Base64.NO_WRAP),
            nonce,
            Key.fromBytes(symKey)
        )
    }
}
```

