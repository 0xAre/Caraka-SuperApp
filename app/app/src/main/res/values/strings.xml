    <!-- ───── Help Screen ───── -->
    <string name="help_title">BANTUAN</string>
    <string name="help_section_basics">Dasar-dasar CARAKA</string>
    <string name="help_q_what_is_mesh">Apa itu jaringan mesh?</string>
    <string name="help_a_what_is_mesh">Mesh adalah jaringan terdesentralisasi di mana setiap perangkat menjadi titik (node) yang bisa meneruskan pesan ke perangkat lain — tanpa server pusat atau internet.</string>
    <string name="help_q_ttl">Apa itu TTL (Time-To-Live)?</string>
    <string name="help_a_ttl">TTL adalah batas jumlah hop (loncatan) sebuah pesan sebelum dibuang. Default CARAKA: 5 hop, mencegah pesan terus bergulir tanpa henti.</string>
    <string name="help_q_e2e">Bagaimana enkripsi bekerja?</string>
    <string name="help_a_e2e">CARAKA menggunakan X25519 untuk pertukaran kunci, Ed25519 untuk tanda tangan digital, dan XChaCha20-Poly1305 untuk enkripsi simetris. Hanya pengirim dan penerima yang bisa membaca pesan.</string>
    <string name="help_q_authority">Apa itu badge ✓ Verified?</string>
    <string name="help_a_authority">Akun BPBD, Polri, dan PMI yang sudah pre-registered punya tanda ✓. Pesan mereka ditandatangani secara kriptografis — tidak bisa dipalsukan oleh warga biasa.</string>
    <string name="help_q_sos">Kapan harus tekan SOS?</string>
    <string name="help_a_sos">Tekan SOS hanya saat darurat nyata (medis, kebakaran, keamanan, bencana). Pesan SOS punya prioritas tertinggi dan disiarkan ke semua node sekitar.</string>
    <string name="help_q_flag">Bagaimana cara melaporkan hoaks?</string>
    <string name="help_a_flag">Tahan (long-press) pesan yang mencurigakan, lalu konfirmasi. Jika 3+ pengguna menandai pesan yang sama, label ⚠️ peringatan muncul untuk semua orang di mesh.</string>

    <string name="help_section_hci">Prinsip HCI yang Diterapkan</string>
    <string name="help_hci_intro">CARAKA dirancang berdasarkan 10 heuristik usability Nielsen dan WCAG 2.1 (Pedoman Aksesibilitas Web).</string>
    <string name="help_hci_visibility">Visibility of System Status — Banner konektivitas + statistik node selalu terlihat.</string>
    <string name="help_hci_match">Match Real World — Ikon 🚨🔥⚠️🌊 mengikuti konvensi darurat yang universal.</string>
    <string name="help_hci_control">User Control &amp; Freedom — Tombol kembali, tahan-untuk-konfirmasi SOS, undo via snackbar.</string>
    <string name="help_hci_consistency">Consistency — Material 3, warna konsisten per peran (amber=otoritas, mint=verified, merah=darurat).</string>
    <string name="help_hci_error_prev">Error Prevention — SOS perlu ditahan 2 detik; dialog konfirmasi sebelum flag/reset.</string>
    <string name="help_hci_recognition">Recognition &gt; Recall — Coach marks pertama kali, badge peran selalu tampil.</string>
    <string name="help_hci_flexibility">Flexibility &amp; Efficiency — Hold gesture, swipe back, toggle bahasa.</string>
    <string name="help_hci_minimalist">Aesthetic &amp; Minimalist Design — Tema gelap taktis, hierarki visual yang jelas.</string>
    <string name="help_hci_recovery">Error Recovery — Pesan error inline dengan saran perbaikan.</string>
    <string name="help_hci_help">Help &amp; Documentation — Layar ini sendiri 🙂</string>

    <string name="help_section_a11y">Aksesibilitas</string>
    <string name="help_a11y_a">CARAKA mendukung TalkBack (pembaca layar), penskalaan teks sistem hingga 200%, kontras AAA opsional, getaran haptik, target sentuh ≥48dp, dan navigasi keyboard.</string>
