<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.GarudaMesh" parent="android:Theme.Material.Light.NoActionBar" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/caraka_qr_scanner_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_caraka_logo_white</item>
        <item name="postSplashScreenTheme">@style/Theme.GarudaMesh</item>
    </style>

    <style name="Theme.Caraka.Scanner" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/caraka_qr_scanner_background</item>
        <item name="android:colorAccent">@color/caraka_qr_scanner_primary</item>
    </style>
</resources>
