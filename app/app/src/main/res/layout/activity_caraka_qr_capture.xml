<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/caraka_qr_scanner_background">

    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/zxing_barcode_scanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:zxing_framing_rect_height="@dimen/caraka_qr_frame_size"
        app:zxing_framing_rect_width="@dimen/caraka_qr_frame_size"
        app:zxing_preview_scaling_strategy="centerCrop"
        app:zxing_scanner_layout="@layout/caraka_zxing_barcode_scanner"
        app:zxing_use_texture_view="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="20dp"
        android:paddingEnd="18dp"
        android:paddingBottom="12dp">

        <Button
            android:id="@+id/qr_scanner_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_qr_scanner_button"
            android:contentDescription="Tutup scanner"
            android:fontFamily="@font/manrope_bold"
            android:gravity="center"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:text="X"
            android:textAllCaps="false"
            android:textColor="@color/caraka_qr_scanner_text"
            android:textSize="16sp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/qr_scanner_torch"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:background="@drawable/bg_qr_scanner_button"
            android:contentDescription="Nyalakan flash"
            android:fontFamily="@font/manrope_bold"
            android:gravity="center"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:minWidth="82dp"
            android:minHeight="48dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Flash"
            android:textAllCaps="false"
            android:textColor="@color/caraka_qr_scanner_text"
            android:textSize="12sp" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="@dimen/caraka_qr_frame_size"
        android:layout_height="@dimen/caraka_qr_frame_size"
        android:layout_gravity="center"
        android:importantForAccessibility="no">

        <View
            android:layout_width="@dimen/caraka_qr_frame_corner_length"
            android:layout_height="@dimen/caraka_qr_frame_corner_thickness"
            android:layout_gravity="top|start"
            android:background="@drawable/bg_qr_scanner_corner" />

        <View
            android:layout_width="@dimen/caraka_qr_frame_corner_thickness"
            android:layout_height="@dimen/caraka_qr_frame_corner_length"
            android:layout_gravity="top|start"
            android:background="@drawable/bg_qr_scanner_corner" />

        <View
            android:layout_width="@dimen/caraka_qr_frame_corner_length"
            android:layout_height="@dimen/caraka_qr_frame_corner_thickness"
            android:layout_gravity="top|end"
            android:background="@drawable/bg_qr_scanner_corner" />

        <View
            android:layout_width="@dimen/caraka_qr_frame_corner_thickness"
            android:layout_height="@dimen/caraka_qr_frame_corner_length"
            android:layout_gravity="top|end"
            android:background="@drawable/bg_qr_scanner_corner" />

        <View
            android:layout_width="@dimen/caraka_qr_frame_corner_length"
            android:layout_height="@dimen/caraka_qr_frame_corner_thickness"
            android:layout_gravity="bottom|start"
            android:background="@drawable/bg_qr_scanner_corner" />

        <View
            android:layout_width="@dimen/caraka_qr_frame_corner_thickness"
            android:layout_height="@dimen/caraka_qr_frame_corner_length"
            android:layout_gravity="bottom|start"
            android:background="@drawable/bg_qr_scanner_corner" />

        <View
            android:layout_width="@dimen/caraka_qr_frame_corner_length"
            android:layout_height="@dimen/caraka_qr_frame_corner_thickness"
            android:layout_gravity="bottom|end"
            android:background="@drawable/bg_qr_scanner_corner" />

        <View
            android:layout_width="@dimen/caraka_qr_frame_corner_thickness"
            android:layout_height="@dimen/caraka_qr_frame_corner_length"
            android:layout_gravity="bottom|end"
            android:background="@drawable/bg_qr_scanner_corner" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="28dp"
        android:background="@drawable/bg_qr_scanner_panel"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="16dp"
        android:paddingEnd="18dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/manrope_bold"
            android:text="Scan QR identitas"
            android:textColor="@color/caraka_qr_scanner_text"
            android:textSize="18sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="@font/inter_regular"
            android:lineSpacingExtra="2dp"
            android:text="Pegang HP tetap tegak. Posisikan QR peer di dalam kotak sampai terbaca otomatis."
            android:textColor="@color/caraka_qr_scanner_text_muted"
            android:textSize="14sp" />
    </LinearLayout>
</FrameLayout>
