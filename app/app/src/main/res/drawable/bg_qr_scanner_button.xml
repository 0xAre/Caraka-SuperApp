<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/caraka_qr_scanner_primary" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/caraka_qr_scanner_surface" />
            <stroke
                android:width="1dp"
                android:color="@color/caraka_qr_scanner_surface_border" />
            <corners android:radius="24dp" />
        </shape>
    </item>
</selector>
