    <!-- ───── Help Screen ───── -->
    <string name="help_title">HELP</string>
    <string name="help_section_basics">CARAKA Basics</string>
    <string name="help_q_what_is_mesh">What is a mesh network?</string>
    <string name="help_a_what_is_mesh">A mesh is a decentralized network where every device acts as a node that can forward messages to other devices — without a central server or internet.</string>
    <string name="help_q_ttl">What is TTL (Time-To-Live)?</string>
    <string name="help_a_ttl">TTL caps the number of hops a message can take before being discarded. CARAKA default: 5 hops, preventing messages from circulating forever.</string>
    <string name="help_q_e2e">How does encryption work?</string>
    <string name="help_a_e2e">CARAKA uses X25519 for key exchange, Ed25519 for digital signatures, and XChaCha20-Poly1305 for symmetric encryption. Only the sender and recipient can read the message.</string>
    <string name="help_q_authority">What is the ✓ Verified badge?</string>
    <string name="help_a_authority">Pre-registered BPBD, Polri, and PMI accounts carry a ✓. Their messages are cryptographically signed — civilians cannot impersonate them.</string>
    <string name="help_q_sos">When should I press SOS?</string>
    <string name="help_a_sos">Press SOS only for real emergencies (medical, fire, security, disaster). SOS messages carry top priority and are broadcast to all nearby nodes.</string>
    <string name="help_q_flag">How do I report a hoax?</string>
    <string name="help_a_flag">Long-press the suspicious message and confirm. When 3+ users flag the same message, a ⚠️ warning appears for everyone in the mesh.</string>

    <string name="help_section_hci">HCI Principles Applied</string>
    <string name="help_hci_intro">CARAKA is designed against the 10 Nielsen usability heuristics and WCAG 2.1.</string>
    <string name="help_hci_visibility">Visibility of System Status — Connectivity banner + node stats always visible.</string>
    <string name="help_hci_match">Match Real World — Icons 🚨🔥⚠️🌊 follow universal emergency conventions.</string>
    <string name="help_hci_control">User Control &amp; Freedom — Back buttons, hold-to-confirm SOS, snackbar undo.</string>
    <string name="help_hci_consistency">Consistency — Material 3, color-coded roles (amber=authority, mint=verified, red=emergency).</string>
    <string name="help_hci_error_prev">Error Prevention — SOS requires 2-second hold; confirmation dialog before flag/reset.</string>
    <string name="help_hci_recognition">Recognition &gt; Recall — First-run coach marks, role badges always shown.</string>
    <string name="help_hci_flexibility">Flexibility &amp; Efficiency — Hold gestures, swipe back, language toggle.</string>
    <string name="help_hci_minimalist">Aesthetic &amp; Minimalist Design — Tactical dark theme, clear visual hierarchy.</string>
    <string name="help_hci_recovery">Error Recovery — Inline error messages with corrective suggestions.</string>
    <string name="help_hci_help">Help &amp; Documentation — This very screen 🙂</string>

    <string name="help_section_a11y">Accessibility</string>
    <string name="help_a11y_a">CARAKA supports TalkBack (screen reader), system font scaling up to 200%, optional AAA contrast, haptic feedback, ≥48dp touch targets, and keyboard navigation.</string>
